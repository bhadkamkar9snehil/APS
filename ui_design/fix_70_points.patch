+/* X-APS corrected stylesheet
+   Consolidated into a single coherent system.
+   Duplicate root blocks, conflicting component definitions, and layered overrides removed.
+*/
+
+:root {
+  /* Core colors */
+  --bg: #f4f7fb;
+  --bg-accent: #eef4ff;
+  --shell: #ffffff;
+  --panel: #ffffff;
+  --panel-soft: #fbfcfe;
+  --panel-muted: #f7f9fc;
+  --text: #0f172a;
+  --text-soft: #475569;
+  --text-faint: #94a3b8;
+  --border: #dbe4ee;
+  --border-soft: #e9eef5;
+
+  /* Semantic colors */
+  --brand: #7c3aed;
+  --brand-2: #0f9f8c;
+  --brand-soft: #f4efff;
+  --primary: #7c3aed;
+  --success: #16a34a;
+  --success-soft: #f0fdf4;
+  --warning: #d97706;
+  --warning-soft: #fff7ed;
+  --danger: #dc2626;
+  --danger-soft: #fef2f2;
+  --info: #2563eb;
+  --info-soft: #eff6ff;
+
+  /* Planning aliases */
+  --plan-good: var(--success);
+  --plan-warn: var(--warning);
+  --plan-bad: var(--danger);
+  --plan-info: var(--info);
+
+  /* Plant colors */
+  --eaf: #f97316;
+  --lrf: #8b5cf6;
+  --vd: #14b8a6;
+  --ccm: #22c55e;
+  --rm: #64748b;
+
+  /* Typography */
+  --font-xs: 0.55rem;
+  --font-sm: 0.65rem;
+  --font-md: 0.8rem;
+  --font-lg: 0.95rem;
+  --font-xl: 1.1rem;
+  --font-page-title: 1.2rem;
+
+  /* Spacing */
+  --spacing-xs: 0.4rem;
+  --spacing-sm: 0.6rem;
+  --spacing-md: 0.9rem;
+  --spacing-lg: 1.2rem;
+  --padding-compact: 0.5rem 0.65rem;
+  --padding-standard: 0.8rem 0.95rem;
+  --padding-spacious: 1rem 1rem;
+
+  /* Sizing */
+  --height-input: 2.2rem;
+  --height-btn: 2.35rem;
+  --height-card-header: 2.4rem;
+  --height-metric: 4.8rem;
+
+  /* Radius */
+  --radius-xs: 0.2rem;
+  --radius-sm: 0.4rem;
+  --radius: 0.65rem;
+  --radius-lg: 0.9rem;
+  --radius-xl: 1rem;
+  --radius-pill: 999px;
+
+  /* Effects */
+  --shadow: 0 0.35rem 1rem rgba(15, 23, 42, 0.05);
+  --shadow-soft: 0 0.2rem 0.9rem rgba(15, 23, 42, 0.04);
+  --shadow-dialog: 0 1.25rem 3.5rem rgba(15, 23, 42, 0.28);
+
+  --card-bg: var(--panel);
+}
+
+* { box-sizing: border-box; }
+html, body { height: 100%; }
+
+body {
+  margin: 0;
+  font-family: Inter, ui-sans-serif, system-ui, -apple-system, "Segoe UI", sans-serif;
+  color: var(--text);
+  background:
+    radial-gradient(circle at top right, rgba(124, 58, 237, 0.08), transparent 28%),
+    radial-gradient(circle at bottom left, rgba(15, 159, 140, 0.05), transparent 24%),
+    linear-gradient(180deg, #f8fafc 0%, #f3f6fb 100%);
+}
+
+button, input, select, textarea { font: inherit; }
+
+.app {
+  height: 100vh;
+  padding: 0.5rem;
+  overflow: hidden;
+}
+
+.shell {
+  height: calc(100vh - 1rem);
+  border: 1px solid rgba(219, 228, 238, 0.92);
+  background: var(--shell);
+  border-radius: var(--radius-sm);
+  overflow: hidden;
+  box-shadow: 0 0.125rem 0.25rem rgba(15, 23, 42, 0.05), 0 1.25rem 2.5rem rgba(15, 23, 42, 0.08);
+  display: flex;
+  flex-direction: column;
+  position: relative;
+}
+
+.top {
+  border-bottom: 1px solid var(--border-soft);
+  background: #fff;
+  flex-shrink: 0;
+  display: flex;
+  flex-direction: column;
+}
+
+.top-summary {
+  padding: 0.6rem 1rem 0.75rem;
+  flex-shrink: 0;
+  overflow: hidden;
+}
+
+.top-controls {
+  padding: 0.7rem 1rem;
+  display: flex;
+  justify-content: flex-start;
+  align-items: center;
+  gap: 0.75rem;
+  flex-wrap: nowrap;
+  flex-shrink: 0;
+  background: linear-gradient(180deg, rgba(248, 250, 252, 0.95), rgba(255, 255, 255, 0.98));
+  border-bottom: 1px solid var(--border-soft);
+  overflow: hidden;
+}
+
+.status-group,
+.control-group {
+  display: flex;
+  align-items: center;
+  gap: 0.6rem;
+}
+
+.brand-row { display: block; min-width: 0; }
+
+.summary-grid {
+  display: grid;
+  grid-template-columns: repeat(6, minmax(0, 1fr));
+  gap: 0.65rem;
+  min-width: 0;
+  flex: 1;
+}
+
+.metric {
+  border: 1px solid var(--border);
+  border-radius: 0.8rem;
+  background: linear-gradient(180deg, #ffffff, #fbfcff);
+  padding: 0.8rem 0.9rem;
+  min-width: 0;
+  min-height: var(--height-metric);
+  display: flex;
+  flex-direction: column;
+  justify-content: center;
+  box-shadow: var(--shadow-soft);
+  transition: transform 0.2s, box-shadow 0.2s;
+}
+
+.metric:hover {
+  transform: translateY(-1px);
+  box-shadow: var(--shadow);
+}
+
+.metric-label {
+  font-size: 0.72rem;
+  text-transform: uppercase;
+  letter-spacing: 0.05em;
+  font-weight: 750;
+  color: var(--text-soft);
+  margin-bottom: 0.25rem;
+  white-space: nowrap;
+  overflow: hidden;
+  text-overflow: ellipsis;
+}
+
+.metric-value {
+  font-size: 1.35rem;
+  font-weight: 900;
+  line-height: 1.1;
+  color: var(--text);
+  white-space: nowrap;
+  overflow: hidden;
+  text-overflow: ellipsis;
+}
+
+.metric-sub {
+  font-size: 0.78rem;
+  color: var(--text-soft);
+  margin-top: 0.25rem;
+  white-space: nowrap;
+  overflow: hidden;
+  text-overflow: ellipsis;
+}
+
+.metric.success { background: var(--success-soft); border-color: rgba(22, 163, 74, 0.2); }
+.metric.success .metric-value { color: var(--success); }
+.metric.warn { background: var(--warning-soft); border-color: rgba(217, 119, 6, 0.2); }
+.metric.warn .metric-value { color: var(--warning); }
+.metric.danger { background: var(--danger-soft); border-color: rgba(220, 38, 38, 0.2); }
+.metric.danger .metric-value { color: var(--danger); }
+.metric.info .metric-value { color: var(--info); }
+
+.chip {
+  height: 1.75rem;
+  padding: 0 0.7rem;
+  font-size: var(--font-sm);
+  font-weight: 650;
+  border-radius: var(--radius-sm);
+  border: 1px solid var(--border-soft);
+  background: var(--panel-muted);
+  color: var(--text-soft);
+  display: inline-flex;
+  align-items: center;
+  gap: 0.4rem;
+}
+
+.chip .dot {
+  width: 0.38rem;
+  height: 0.38rem;
+  border-radius: 50%;
+  background: #cbd5e1;
+}
+
+.chip.success { background: var(--success-soft); border-color: rgba(22, 163, 74, 0.15); color: var(--success); }
+.chip.success .dot { background: var(--success); }
+.chip.warn { background: var(--warning-soft); border-color: rgba(217, 119, 6, 0.15); color: var(--warning); }
+.chip.warn .dot { background: var(--warning); }
+.chip.danger { background: var(--danger-soft); border-color: rgba(220, 38, 38, 0.15); color: var(--danger); }
+.chip.danger .dot { background: var(--danger); }
+.chip.info { background: var(--info-soft); border-color: rgba(37, 99, 235, 0.15); color: var(--info); }
+.chip.info .dot { background: var(--info); }
+
+.btn {
+  font-family: inherit;
